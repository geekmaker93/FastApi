# AgroMonitoring API
AGRO_API_KEY=your_agromonitoring_api_key

# Farmonaut API  
FARMONAUT_API_KEY=your_farmonaut_api_key

# Google Earth Engine
GEE_API_KEY=your_gee_api_key
GEE_PROJECT_ID=your_gee_project_id

# Cloud AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key
CLOUD_AI_MODEL=gemini-2.5-flash-lite
CLOUD_AI_TIMEOUT=35

# Web search
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id
SERPAPI_KEY=your_serpapi_key

# External data
PERENUAL_API_KEY=your_perenual_api_key
TREFLE_API_KEY=your_trefle_api_key
USDA_API_KEY=your_usda_api_key

# Firebase
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_CREDENTIALS_JSON=

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/crop_app

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
